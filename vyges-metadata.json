{
  "$schema": "https://vyges.com/schema/v1/vyges-metadata.schema.json",
  "name": "vyges-rv-plic-lite",
  "version": "0.1.0",
  "description": "Lightweight RISC-V PLIC with native TL-UL interface. Supports up to 32 sources, 3-bit priority, claim/complete, single hart target.",
  "category": "infrastructure",
  "license": "Apache-2.0",
  "owner": "Vyges Inc.",
  "maturity": "development",
  "created": "2026-03-28T01:34:10Z",
  "updated": "2026-03-28T01:34:10Z",
  "interfaces": [
    {
      "type": "clock",
      "name": "clock",
      "signals": [
        {
          "name": "clk_i",
          "direction": "input",
          "type": "clock",
          "width": 1
        }
      ]
    },
    {
      "type": "reset",
      "name": "reset",
      "signals": [
        {
          "name": "rst_ni",
          "direction": "input",
          "type": "reset",
          "width": 1,
          "active_level": "low"
        }
      ]
    },
    {
      "name": "tl_i / tl_o",
      "type": "tl-ul",
      "role": "device",
      "description": "TileLink-UL slave port for register access"
    },
    {
      "name": "intr_src_i",
      "type": "irq-source-array",
      "role": "sink",
      "width": "NUM_SOURCES",
      "description": "Level-sensitive interrupt source inputs (active-high)"
    },
    {
      "name": "irq_o",
      "type": "irq-output",
      "role": "source",
      "description": "Interrupt output to hart (asserted when any enabled source above threshold is pending)"
    }
  ],
  "registers": [
    {
      "name": "PRIO",
      "offset": "0x000",
      "count": 32,
      "stride": 4,
      "access": "RW",
      "width": 3,
      "description": "Priority for source N (0=disabled, 7=highest)"
    },
    {
      "name": "PENDING",
      "offset": "0x080",
      "access": "RO",
      "width": 32,
      "description": "Pending interrupt bitmap"
    },
    {
      "name": "ENABLE",
      "offset": "0x100",
      "access": "RW",
      "width": 32,
      "description": "Interrupt enable bitmap"
    },
    {
      "name": "THRESHOLD",
      "offset": "0x200",
      "access": "RW",
      "width": 3,
      "description": "Priority threshold \u2014 only sources with priority > threshold generate irq_o"
    },
    {
      "name": "CLAIM_COMPLETE",
      "offset": "0x204",
      "access": "RW",
      "width": 32,
      "description": "Read returns highest-priority pending source ID (claim). Write signals completion for source ID."
    }
  ],
  "parameters": [
    {
      "name": "NUM_SOURCES",
      "type": "int unsigned",
      "default": 32,
      "range": "1..32",
      "description": "Number of external interrupt sources"
    }
  ],
  "dependencies": [
    {
      "name": "opentitan-tlul",
      "version": ">=0.1.0",
      "description": "Provides tlul_pkg with TL-UL type definitions (tl_h2d_t, tl_d2h_t, opcodes)"
    }
  ],
  "trust": {
    "provenance": "vyges-original",
    "racl_required": false,
    "lifecycle_required": false,
    "notes": "No OpenTitan RACL or lifecycle dependencies. Standalone PLIC suitable for lightweight SoCs."
  },
  "rtl_files": [
    "rtl/rv_plic_lite.sv"
  ],
  "branding": {
    "display_name": "PLIC"
  },
  "integration": {
    "soc_generator_hints": {
      "top_module": "rv_plic_lite",
      "clock": {
        "port": "clk_i"
      },
      "reset": {
        "port": "rst_ni",
        "polarity": "active_low"
      },
      "bus_slave": {
        "protocol": "TL-UL",
        "ports": {
          "tl_i": "tl_i",
          "tl_o": "tl_o"
        }
      },
      "interrupts": [],
      "parameters": [
        {
          "name": "NUM_SOURCES",
          "maps_to": "config.NUM_SOURCES",
          "default": 32
        }
      ]
    }
  },
  "test": {
    "testbenches": [
      {
        "name": "soc_integration",
        "path": "tb/cocotb/",
        "framework": "cocotb",
        "simulators": [
          "verilator"
        ],
        "description": "SoC-level integration verified in edge-sensor-soc"
      }
    ],
    "coverage": "functional"
  }
}
